{
    "name": "orangehrm-qa",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "test": "playwright test",
        "test:integration": "playwright test tests/integration --project=integration",
        "test:system": "playwright test tests/system --project=system",
        "test:e2e": "playwright test tests/e2e --project=e2e",
        "test:smoke": "playwright test tests/e2e/smoke --project=e2e",
        "test:local": "ENV=local playwright test",
        "test:staging": "ENV=staging playwright test",
        "report": "allure generate reports/allure-results -o reports/allure-report --clean && allure open reports/allure-report",
        "agent:plan": "ts-node agents/planner/index.ts",
        "agent:generate": "ts-node agents/generator/index.ts",
        "agent:heal": "ts-node agents/healer/index.ts",
        "docker:up": "docker compose -f docker/docker-compose.yml up -d",
        "docker:down": "docker compose -f docker/docker-compose.yml down",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "dotenv": "^16.4.5",
        "mysql2": "^3.11.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@playwright/test": "^1.48.0",
        "@types/node": "^22.0.0",
        "allure-playwright": "^3.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.0"
    }
}