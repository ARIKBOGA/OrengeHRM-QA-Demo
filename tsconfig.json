{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "commonjs",
    "lib":               ["ES2022"],
    "strict":            true,
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "outDir":            "dist",
    "rootDir":           ".",
    "baseUrl":           ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@fixtures/*": ["src/fixtures/*"],
      "@pages/*":    ["src/pages/*"],
      "@utils/*":    ["src/utils/*"],
      "@data/*":     ["src/data/*"],
      "@t/*":        ["src/types/*"],
      "@config/*":   ["src/config/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*", "tests/**/*", "agents/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
